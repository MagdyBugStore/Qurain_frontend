rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // Helper Functions - الدوال المساعدة
    // ============================================
    
    // Check if user is authenticated
    // التحقق من تسجيل دخول المستخدم
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if user owns the document by userId field
    // التحقق من أن المستخدم يملك المستند حسب حقل userId
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Check if user is admin
    // التحقق من أن المستخدم مشرف
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.accountType == 'admin';
    }
    
    // Check if user owns document by teacherId field
    // التحقق من أن المستخدم يملك المستند حسب حقل teacherId
    function ownsByTeacherId(teacherId) {
      return isAuthenticated() && teacherId == request.auth.uid;
    }
    
    // Check if user owns document by userId field in data
    // التحقق من أن المستخدم يملك المستند حسب حقل userId في البيانات
    function ownsByDataUserId(userId) {
      return isAuthenticated() && userId == request.auth.uid;
    }
    
    // Check if user is student or teacher owner of session/task/log
    // التحقق من أن المستخدم طالب أو معلم مالك للجلسة/المهمة/السجل
    function isStudentOrTeacherOwner(studentId, teacherId) {
      return isAuthenticated() && 
        (request.auth.uid == studentId || request.auth.uid == teacherId);
    }
    
    // Check if userId field is not being changed (for partial updates)
    // التحقق من أن حقل userId لا يتم تغييره (للتحديثات الجزئية)
    function userIdNotChanged(resourceUserId) {
      return request.resource.data.get('userId', resourceUserId) == resourceUserId;
    }
    
    // Check if teacherId field is not being changed
    // التحقق من أن حقل teacherId لا يتم تغييره
    function teacherIdNotChanged(resourceTeacherId) {
      return request.resource.data.get('teacherId', resourceTeacherId) == resourceTeacherId;
    }
    
    // ============================================
    // Users Collection - مجموعة المستخدمين
    // ============================================
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin() || resource.data.accountType == 'teacher';
      allow create: if isAuthenticated() 
                    && request.auth.uid == userId
                    && request.resource.data.uid == userId
                    && request.resource.data.email == request.auth.token.email;
      allow update: if (isOwner(userId)
                    && request.resource.data.uid == userId
                    && request.resource.data.email == resource.data.email) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();
    }
    
    // ============================================
    // Teacher Applications - طلبات المعلمين
    // ============================================
    match /teacherApplications/{applicationId} {
      allow read: if (isAuthenticated() && resource.data.userId == request.auth.uid) 
                  || isAdmin() 
                  || resource.data.status == 'approved';
      allow create: if isAuthenticated() 
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.userEmail == request.auth.token.email;
      allow update: if (isAuthenticated() 
                    && ownsByDataUserId(resource.data.userId)
                    && userIdNotChanged(resource.data.userId)) || isAdmin();
      allow delete: if ownsByDataUserId(resource.data.userId) || isAdmin();
    }
    
    // ============================================
    // Reviews - التقييمات
    // ============================================
    match /reviews/{reviewId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if ownsByDataUserId(resource.data.userId) || isAdmin();
    }
    
    // ============================================
    // Sessions - الجلسات
    // ============================================
    match /sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isStudentOrTeacherOwner(resource.data.studentId, resource.data.teacherId) || isAdmin();
      allow delete: if isStudentOrTeacherOwner(resource.data.studentId, resource.data.teacherId) || isAdmin();
    }
    
    // ============================================
    // Teacher Availability - توفر المعلمين
    // ============================================
    match /teacherAvailability/{teacherId} {
      allow read: if isAuthenticated();
      allow create: if ownsByTeacherId(teacherId);
      allow update: if ownsByTeacherId(teacherId) || isAdmin();
      allow delete: if ownsByTeacherId(teacherId) || isAdmin();
    }
    
    // ============================================
    // Teacher Ijazahs - إجازات المعلمين
    // ============================================
    match /teacherIjazahs/{ijazahId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() 
                    && request.resource.data.teacherId == request.auth.uid;
      allow update: if (ownsByDataUserId(resource.data.teacherId)
                    && teacherIdNotChanged(resource.data.teacherId)) || isAdmin();
      allow delete: if ownsByDataUserId(resource.data.teacherId) || isAdmin();
    }
    
    // ============================================
    // Teacher Wallets - محافظ المعلمين
    // ============================================
    match /teacherWallets/{walletId} {
      allow read: if ownsByDataUserId(resource.data.teacherId) || isAdmin();
      allow create: if isAuthenticated() 
                    && request.resource.data.teacherId == request.auth.uid;
      allow update: if (ownsByDataUserId(resource.data.teacherId)
                    && teacherIdNotChanged(resource.data.teacherId)) || isAdmin();
      allow delete: if ownsByDataUserId(resource.data.teacherId) || isAdmin();
    }
    
    // ============================================
    // Teacher Transactions - معاملات المعلمين
    // ============================================
    match /teacherTransactions/{transactionId} {
      allow read: if ownsByDataUserId(resource.data.teacherId) || isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }
    
    // ============================================
    // Withdrawal Requests - طلبات السحب
    // ============================================
    match /withdrawalRequests/{requestId} {
      allow read: if ownsByDataUserId(resource.data.teacherId) || isAdmin();
      allow create: if isAuthenticated() 
                    && request.resource.data.teacherId == request.auth.uid;
      allow update: if (ownsByDataUserId(resource.data.teacherId)
                    && teacherIdNotChanged(resource.data.teacherId)) || isAdmin();
      allow delete: if ownsByDataUserId(resource.data.teacherId) || isAdmin();
    }
    
    // ============================================
    // Student Tasks - مهام الطلاب
    // ============================================
    match /studentTasks/{taskId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isStudentOrTeacherOwner(resource.data.studentId, resource.data.teacherId) || isAdmin();
      allow delete: if isStudentOrTeacherOwner(resource.data.studentId, resource.data.teacherId) || isAdmin();
    }
    
    // ============================================
    // Memorization Logs - سجلات الحفظ
    // ============================================
    match /memorizationLogs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isStudentOrTeacherOwner(resource.data.studentId, resource.data.teacherId) || isAdmin();
      allow delete: if isStudentOrTeacherOwner(resource.data.studentId, resource.data.teacherId) || isAdmin();
    }
    
    // ============================================
    // Student Activities - نشاطات الطلاب
    // ============================================
    match /studentActivities/{activityId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }
    
    // ============================================
    // Support Tickets - تذاكر الدعم الفني
    // ============================================
    match /supportTickets/{ticketId} {
      allow read: if ownsByDataUserId(resource.data.userId) || isAdmin();
      allow create: if isAuthenticated() 
                    && request.resource.data.userId == request.auth.uid;
      allow update: if (ownsByDataUserId(resource.data.userId)
                    && userIdNotChanged(resource.data.userId)) || isAdmin();
      allow delete: if ownsByDataUserId(resource.data.userId) || isAdmin();
      
      // Replies subcollection - مجموعة ردود التذاكر
      match /replies/{replyId} {
        function getParentTicket() {
          return get(/databases/$(database)/documents/supportTickets/$(ticketId));
        }
        
        function ownsParentTicket() {
          return getParentTicket().data.userId == request.auth.uid;
        }
        
        allow read: if isAuthenticated() && (ownsParentTicket() || isAdmin());
        allow create: if isAuthenticated() && (ownsParentTicket() || isAdmin());
        allow update, delete: if ownsByDataUserId(resource.data.userId) || isAdmin();
      }
    }
    
    // ============================================
    // Subscriptions - الاشتراكات الشهرية
    // ============================================
    match /subscriptions/{subscriptionId} {
      // يمكن للطالب أو المعلم صاحب الاشتراك، أو الأدمن، قراءة بيانات الاشتراك
      allow read: if isStudentOrTeacherOwner(resource.data.studentId, resource.data.teacherId) || isAdmin();

      // يمكن للطالب فقط إنشاء اشتراك باسمه
      allow create: if isAuthenticated()
                    && request.resource.data.studentId == request.auth.uid;

      // يمكن للطالب أو المعلم صاحب الاشتراك، أو الأدمن، تعديل أو حذف الاشتراك
      allow update, delete: if isStudentOrTeacherOwner(resource.data.studentId, resource.data.teacherId) || isAdmin();
    }
    
    // ============================================
    // Default Deny - الرفض الافتراضي
    // ============================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
