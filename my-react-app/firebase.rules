rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    // دالة مساعدة للتحقق من تسجيل دخول المستخدم
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the document
    // دالة مساعدة للتحقق من أن المستخدم يملك المستند
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Users collection - مجموعة المستخدمين
    // Each user can only read and write their own profile
    // كل مستخدم يمكنه قراءة وكتابة ملفه الشخصي فقط
    match /users/{userId} {
      // Allow read if user is authenticated and owns the document
      // السماح بالقراءة إذا كان المستخدم مسجلاً ويملك المستند
      allow read: if isOwner(userId);
      
      // Allow create if user is authenticated and creating their own document
      // السماح بالإنشاء إذا كان المستخدم مسجلاً وينشئ مستنده الخاص
      allow create: if isAuthenticated() 
                    && request.auth.uid == userId
                    && request.resource.data.uid == userId
                    && request.resource.data.email == request.auth.token.email;
      
      // Allow update if user is authenticated and owns the document
      // السماح بالتحديث إذا كان المستخدم مسجلاً ويملك المستند
      allow update: if isOwner(userId)
                    && request.resource.data.uid == userId
                    && request.resource.data.email == resource.data.email;
      
      // Allow delete if user is authenticated and owns the document
      // السماح بالحذف إذا كان المستخدم مسجلاً ويملك المستند
      allow delete: if isOwner(userId);
    }
    
    // Teacher Applications collection - مجموعة طلبات المعلمين
    // Allow authenticated users to create their own teacher applications
    // السماح للمستخدمين المسجلين بإنشاء طلبات المعلمين الخاصة بهم
    match /teacherApplications/{applicationId} {
      // Allow read if user is authenticated and owns the application
      // السماح بالقراءة إذا كان المستخدم مسجلاً ويملك الطلب
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // Allow create if user is authenticated and creating their own application
      // السماح بالإنشاء إذا كان المستخدم مسجلاً وينشئ طلبه الخاص
      allow create: if isAuthenticated() 
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.userEmail == request.auth.token.email;
      
      // Allow update if user is authenticated and owns the application
      // السماح بالتحديث إذا كان المستخدم مسجلاً ويملك الطلب
      allow update: if isAuthenticated() 
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.userId == resource.data.userId;
      
      // Allow delete if user is authenticated and owns the application
      // السماح بالحذف إذا كان المستخدم مسجلاً ويملك الطلب
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // Default deny rule for all other collections
    // قاعدة الرفض الافتراضية لجميع المجموعات الأخرى
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
